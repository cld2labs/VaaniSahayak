# ──────────────────────────────────────────────
# Vaani Sahayak — Environment Configuration
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ──────────────────────────────────────────────
# HuggingFace
# ──────────────────────────────────────────────
# Required to download gated models (Param-1, Indic Parler-TTS)
# Get your token at: https://huggingface.co/settings/tokens
HF_TOKEN=

# ──────────────────────────────────────────────
# Model Server Endpoints
# ──────────────────────────────────────────────
# Param-1 LLM server (server_param1.py)
VLLM_LLM_URL=http://localhost:8001/v1

# Indic Parler-TTS server (server_tts.py)
TTS_SERVER_URL=http://localhost:8003

# ──────────────────────────────────────────────
# Backend Server
# ──────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ──────────────────────────────────────────────
# Enterprise Inference (EI) GPU Stack — Optional
# ──────────────────────────────────────────────
# When set, the backend calls a remote GPU-accelerated TTS server
# instead of the local server_tts.py. Leave blank to use local TTS.

# APISIX gateway URL for TTS
EI_TTS_URL=

# Option A: Static Bearer token (no Keycloak needed)
EI_TTS_TOKEN=

# Option B: Keycloak OAuth2 (client_credentials flow)
EI_KEYCLOAK_URL=
EI_KEYCLOAK_REALM=ei
EI_CLIENT_ID=
EI_CLIENT_SECRET=

# SSL verification — set "false" for self-signed certs in dev
EI_VERIFY_SSL=true

# ── Param-1 LLM server (local, always used) ───────────────────────────
VLLM_LLM_URL=http://localhost:8001/v1

# ── TTS — local server (used when EI is not configured) ───────────────
TTS_SERVER_URL=http://localhost:8003

# ── TTS — Enterprise Inference (EI) GPU stack ─────────────────────────
# When all four EI vars are set, the backend prefers EI TTS over local.
# Leave blank to use local server_tts.py.
#
# EI_TTS_URL:        APISIX gateway URL for the TTS endpoint
#                    e.g. https://apisix.example.com/indic-parler-tts
#
# EI_KEYCLOAK_URL:   Keycloak base URL (without /realms/...)
#                    e.g. https://keycloak.example.com
#
# EI_KEYCLOAK_REALM: Keycloak realm that holds the client
#                    e.g. ei
#
# EI_CLIENT_ID:      OAuth2 client_id  (from Keycloak client config)
# EI_CLIENT_SECRET:  OAuth2 client_secret
#
# EI_VERIFY_SSL:     Set to "false" only for dev with self-signed certs
EI_TTS_URL=
EI_KEYCLOAK_URL=
EI_KEYCLOAK_REALM=ei
EI_CLIENT_ID=
EI_CLIENT_SECRET=
EI_VERIFY_SSL=true
